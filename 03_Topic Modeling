# Stage 3: 잠재 디리클레 할당(LDA) 토픽 모델링 (Topic Modeling)
# ==========================================
import pandas as pd
import ast
import matplotlib.pyplot as plt
from sklearn.feature_extraction.text import CountVectorizer
from sklearn.decomposition import LatentDirichletAllocation
import warnings
warnings.filterwarnings('ignore')

# 한글 폰트 설정 (시각화용, 윈도우 기준 맑은 고딕)
plt.rcParams['font.family'] = 'Malgun Gothic'
plt.rcParams['axes.unicode_minus'] = False

print("\n[Stage 3] LDA 토픽 모델링 및 최적 토픽 수(K) 탐색을 시작합니다.")

# 1. 2단계 전처리 데이터 로드
try:
    news_df = pd.read_csv("news_preprocessed.csv")
    comments_df = pd.read_csv("comments_preprocessed.csv")
    print("  - 전처리된 데이터를 성공적으로 불러왔습니다.")
except FileNotFoundError:
    print("  - [오류] 2단계 전처리 데이터(CSV)를 찾을 수 없습니다.")
    exit()

# 2. 문자열로 저장된 리스트를 실제 파이썬 리스트로 변환 (ast.literal_eval 활용)
def parse_tokens(x):
    try:
        return ast.literal_eval(x)
    except:
        return []

news_df['tokens'] = news_df['tokens'].apply(parse_tokens)
comments_df['tokens'] = comments_df['tokens'].apply(parse_tokens)

# 빈 토큰 행 2차 필터링
news_df = news_df[news_df['tokens'].map(len) > 0]
comments_df = comments_df[comments_df['tokens'].map(len) > 0]

# 3. 문서 단어 행렬(DTM) 생성 함수
def create_dtm(df, text_col='tokens'):
    docs = df[text_col].apply(lambda x: ' '.join(x))
    # 문서 빈도가 너무 높거나(90% 이상) 너무 낮은(2번 이하) 단어 제외
    vectorizer = CountVectorizer(max_df=0.9, min_df=2)
    dtm = vectorizer.fit_transform(docs)
    return dtm, vectorizer

print("  - 문서-단어 행렬(DTM) 생성 중...")
news_dtm, news_vec = create_dtm(news_df)
comments_dtm, comments_vec = create_dtm(comments_df)


# 4. 최적의 토픽 수(K) 탐색 함수 (Perplexity, Log-Likelihood 기반)
def find_optimal_k(dtm, data_name, min_k=2, max_k=10):
    print(f"\n  [{data_name}] 최적의 토픽 수(K) 탐색 (K={min_k}~{max_k})")
    search_k = range(min_k, max_k + 1)
    log_likelihoods = []
    perplexities = []
    
    for k in search_k:
        lda = LatentDirichletAllocation(n_components=k, random_state=42)
        lda.fit(dtm)
        score = lda.score(dtm)
        perp = lda.perplexity(dtm)
        
        log_likelihoods.append(score)
        perplexities.append(perp)
        print(f"    - K={k}: Log-Likelihood={score:.2f}, Perplexity={perp:.2f}")
    
    # 평가 지표 시각화 (논문 삽입용 그래프)
    fig, ax1 = plt.subplots(figsize=(8, 5))
    ax1.plot(search_k, log_likelihoods, 'b-o', label='Log-Likelihood')
    ax1.set_xlabel('Number of Topics (K)')
    ax1.set_ylabel('Log-Likelihood', color='b')
    ax1.tick_params('y', colors='b')
    
    ax2 = ax1.twinx()
    ax2.plot(search_k, perplexities, 'r-s', label='Perplexity')
    ax2.set_ylabel('Perplexity', color='r')
    ax2.tick_params('y', colors='r')
    
    plt.title(f'Optimal K Search for {data_name}')
    fig.tight_layout()
    plt.savefig(f'{data_name}_optimal_k.png')
    plt.close()
    print(f"    -> '{data_name}_optimal_k.png' 그래프가 저장되었습니다. (논문 활용)")

# 뉴스 및 댓글 최적 K 탐색 실행
find_optimal_k(news_dtm, "News")
find_optimal_k(comments_dtm, "Comments")


# 5. 최종 LDA 모델 학습 및 토픽별 핵심 키워드 추출
def run_final_lda(dtm, vectorizer, optimal_k, data_name, n_top_words=10):
    print(f"\n  [{data_name}] K={optimal_k}로 최종 모델 학습 및 키워드 추출")
    lda = LatentDirichletAllocation(n_components=optimal_k, random_state=42)
    lda.fit(dtm)
    
    feature_names = vectorizer.get_feature_names_out()
    topic_results = []
    
    for topic_idx, topic in enumerate(lda.components_):
        top_features_ind = topic.argsort()[:-n_top_words - 1:-1]
        top_features = [feature_names[i] for i in top_features_ind]
        topic_results.append(f"Topic #{topic_idx + 1}: " + ", ".join(top_features))
        print(f"    - Topic #{topic_idx + 1}: {', '.join(top_features)}")
        
    return lda

# !!! 연구자가 위 탐색 결과를 바탕으로 직접 결정한 최적 K값을 아래에 입력합니다 !!!
# (초기값으로 양측 모두 5를 설정해 두었습니다. 실행 후 그래프를 보고 수정할 수 있습니다.)
OPTIMAL_K_NEWS = 5 
OPTIMAL_K_COMMENTS = 5 

final_news_lda = run_final_lda(news_dtm, news_vec, OPTIMAL_K_NEWS, "News")
final_comments_lda = run_final_lda(comments_dtm, comments_vec, OPTIMAL_K_COMMENTS, "Comments")

print("\n[Stage 3 완료] 담론 구조 파악을 위한 토픽 모델링이 종료되었습니다.")
