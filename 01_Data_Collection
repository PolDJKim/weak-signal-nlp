# Stage 1: 이원적 데이터 수집 모듈 (Data Collection)
import requests
import json
import pandas as pd
import re
import time
from bs4 import BeautifulSoup
from selenium import webdriver
from selenium.webdriver.chrome.options import Options

# 1. 뉴스 기사 URL 수집 함수 (Selenium)
def collect_naver_news_urls(query, start_date, end_date, max_pages=3): 
    print(f"\n[URL 수집] '{query}' 뉴스 링크 수집을 시작합니다. (목표: {max_pages}쪽)")
    options = Options()
    options.add_argument("disable-blink-features=AutomationControlled")
    options.add_argument("user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36")
    
    # Colab이나 백그라운드 환경 실행 시 아래 주석 해제
    # options.add_argument("--headless") 
    
    driver = webdriver.Chrome(options=options)
    collected_urls = []

    for page in range(1, max_pages + 1):
        start_val = (page - 1) * 10 + 1
        search_url = f"https://search.naver.com/search.naver?where=news&query={query}&sort=2&pd=3&ds={start_date}&de={end_date}&start={start_val}"
        driver.get(search_url)
        time.sleep(2) 
        
        soup = BeautifulSoup(driver.page_source, 'html.parser')
        links = soup.find_all("a")
        for link in links:
            href = link.get('href', '')
            if "n.news.naver.com" in href and "article" in href: 
                collected_urls.append(href)
                
        print(f"  - 검색결과 {page}페이지 완료 (현재 확보된 고유 기사: {len(set(collected_urls))}개)")
        
    driver.quit()
    unique_urls = list(set(collected_urls))
    return unique_urls

# 2. 뉴스 기사 본문 수집 함수 (BeautifulSoup) -> [신규 추가]
def get_naver_news_article(news_url, session):
    try:
        response = session.get(news_url, timeout=5)
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # 제목 추출
        title_tag = soup.select_one('h2#title_area')
        title = title_tag.text.strip() if title_tag else ''
        
        # 본문 추출 (HTML 태그 제거 및 텍스트만 추출)
        body_tag = soup.select_one('div#dic_area')
        body = body_tag.text.strip() if body_tag else ''
        
        # 언론사 추출
        press_tag = soup.select_one('a.media_end_head_top_logo img')
        press = press_tag.get('title', '') if press_tag else ''
        if not press: # 텍스트 형태의 언론사명 대체 탐색
            press_tag_alt = soup.select_one('em.media_end_head_top_logo_text')
            press = press_tag_alt.text.strip() if press_tag_alt else ''
            
        # 날짜 추출
        date_tag = soup.select_one('span.media_end_head_info_datestamp_time')
        date = date_tag.get('data-date-time', date_tag.text.strip()) if date_tag else ''
        
        if not title or not body:
            return None
            
        return {
            'origin_news_url': news_url,
            'press': press,
            'title': title,
            'body': body,
            'date': date
        }
    except Exception as e:
        return None

# 3. 뉴스 댓글 수집 함수 (API jsonp 파싱)
def get_naver_comments_api(news_url, session):
    match = re.search(r'article/(\d+)/(\d+)', news_url)
    if not match:
        return pd.DataFrame()
        
    oid, aid = match.groups()
    object_id = f"news{oid},{aid}"
    
    try:
        session.get(news_url, timeout=5) 
    except:
        pass
        
    headers = {"Referer": news_url}
    api_url = "https://apis.naver.com/commentBox/cbox/web_naver_list_jsonp.json"
    comments_data = []
    page = 1
    seen_comment_ids = set()
    
    while True:
        params = {
            'ticket': 'news',
            'templateId': 'default_society',
            'pool': 'cbox5',
            'lang': 'ko',
            'country': 'KR',
            'objectId': object_id,
            'pageSize': 100,      
            'page': page,
            'sort': 'NEW',  
            'cleanbot': 'false'   
        }
        
        try:
            response = session.get(api_url, headers=headers, params=params, timeout=5)
            json_text = re.sub(r'^[^(]*\((.*)\)[^)]*$', r'\1', response.text) 
            data = json.loads(json_text) 
            
            comments_list = data.get('result', {}).get('commentList', [])
            if not comments_list: 
                break
                
            new_comments_count = 0
            for comment in comments_list:
                comment_no = comment['commentNo']
                if comment_no in seen_comment_ids: 
                    continue
                seen_comment_ids.add(comment_no)
                new_comments_count += 1 
                
                if comment['deleted']:
                    continue
                    
                comments_data.append({
                    'comment_no': comment_no, 
                    'date': comment['regTime'], 
                    'text': comment['contents'],
                    'sympathy_count': comment['sympathyCount'],
                    'antipathy_count': comment['antipathyCount'],
                    'origin_news_url': news_url
                })
            
            if new_comments_count == 0:
                break
            
            page += 1
            time.sleep(0.3) 
            
        except Exception as e:
            break

    return pd.DataFrame(comments_data)


# 4. 통합 실행 파이프라인
SEARCH_KEYWORDS = ["이상동기 범죄"]
SEARCH_PAGES = 3 
start_date = "2023.01.01" # 이상동기 범죄 공론화 시점 고려
end_date = "2025.12.31"

all_news_df = pd.DataFrame()     # 기사 본문 누적용 DF
all_comments_df = pd.DataFrame() # 댓글 누적용 DF

# 전역 세션(Session) 설정
global_session = requests.Session()
global_session.headers.update({
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
})

for keyword in SEARCH_KEYWORDS:
    print(f"\n{'='*50}\n▶ [{keyword}] 키워드 데이터 파이프라인 가동!\n{'='*50}")
    
    news_urls = collect_naver_news_urls(query=keyword, start_date=start_date, end_date=end_date, max_pages=SEARCH_PAGES)
    
    if news_urls:
        print(f"\n[데이터 수집] '{keyword}' 관련 기사 본문 및 댓글을 이원 수집합니다...")
        
        for i, url in enumerate(news_urls):
            print(f"  [{i+1}/{len(news_urls)}] 진행 중... (URL: {url})")
            
            # 1) 기사 본문 수집
            article_data = get_naver_news_article(url, global_session)
            if article_data:
                article_data['Search_Keyword'] = keyword
                # DataFrame에 행 추가
                all_news_df = pd.concat([all_news_df, pd.DataFrame([article_data])], ignore_index=True)
                
                # 2) 해당 기사의 댓글 수집
                df_temp = get_naver_comments_api(url, global_session)
                if not df_temp.empty:
                    df_temp['Search_Keyword'] = keyword
                    all_comments_df = pd.concat([all_comments_df, df_temp], ignore_index=True)
                    print(f"    ↳ 성공: 기사 본문 수집 완료 / 댓글 {len(df_temp)}개 수집")
                else:
                    print("    ↳ 성공: 기사 본문 수집 완료 / 댓글 없음")
            else:
                print("    ↳ 실패: 기사 본문을 불러오지 못했습니다.")
            
            time.sleep(0.4) 
    else:
        print(f"'{keyword}'에 대한 기사 링크를 찾지 못했습니다.")

# 5. 최종 데이터 정제 및 이원화 저장
print("수집 완료! 데이터를 정제하고 분리 저장합니다.")

# (1) 뉴스 기사 데이터(공식 담론) 저장
if not all_news_df.empty:
    all_news_df = all_news_df.drop_duplicates(subset=['origin_news_url'], keep='first').reset_index(drop=True)
    all_news_df.to_csv("news_raw_data.csv", index=False, encoding='utf-8-sig')
    print(f"[✅ 뉴스 기사] 총 {len(all_news_df)}건 -> 'news_raw_data.csv' 저장 완료")
else:
    print("[-] 수집된 뉴스 기사가 없습니다.")

# (2) 댓글 데이터(대중 텐션) 저장
if not all_comments_df.empty:
    all_comments_df['date'] = pd.to_datetime(all_comments_df['date'])
    all_comments_df = all_comments_df.sort_values(by='date').reset_index(drop=True)
    all_comments_df = all_comments_df.drop_duplicates(subset=['text'], keep='first')
    all_comments_df.to_csv("comments_raw_data.csv", index=False, encoding='utf-8-sig')
    print(f"[✅ 댓글 데이터] 총 {len(all_comments_df)}건 -> 'comments_raw_data.csv' 저장 완료")
else:
    print("[-] 수집된 댓글 데이터가 없습니다.")
