# [7단계] 약신호 지표와 다차원 공공 보건/행정 데이터 간의 시차 교차 상관관계(Time-shifted Cross-correlation) 분석
import pandas as pd
import numpy as np
from scipy.stats import pearsonr # 두 데이터의 상관관계(r)와 통계적 유의성(p-value)을 구해주는 통계 마법사
import matplotlib.pyplot as plt

print("[*] 7단계: 사후 예측 검증(Hindcasting)을 위한 데이터를 불러옵니다...")

# 1. 6단계에서 도출된 약신호(Hub 키워드) 시계열 트렌드 데이터 불러오기
signal_trend_df = pd.read_csv("naver_news_monthly_signal_trend.csv")

# 2. 실제 공공 보건/행정 데이터 (예: 심평원 정신질환 진단 통계, 통계청 자살 통계 등)
public_health_df = pd.read_csv("hira_kosis_mental_health_monthly.csv")

# pd.merge: 'date'(날짜)라는 공통 기둥을 기준으로 두 개의 엑셀 표를 하나로 예쁘게 찰싹 붙여줌
merged_df = pd.merge(signal_trend_df, public_health_df, on='date')

# 3. 검증할 정신병리 스펙트럼 타겟 리스트 (질병분류기호 F코드 기준)
target_diseases = {
    'anxiety_F40': '불안장애(F40-F48)',
    'depression_F32': '우울증(F32,F33)',
    'schizophrenia_F20': '조현병(F20-F29)',
    'personality_F60': 'B군성격장애(F60)',
    'suicide_cases': '고의적자해_자살(KOSIS)'
}

max_shift = 3 # 최대 3개월 시차까지 확인 ("댓글 여론이 실제 환자 증가보다 최대 3개월 먼저 움직일까?")
best_results = [] 

print("\n[*] 정신병리 스펙트럼별 시차 교차 상관관계(Cross-Correlation) 분석 시작:")

for col_name, label_name in target_diseases.items():
    print(f"\n▶ {label_name} 분석 중...")
    
    disease_correlations = []
    
    for h in range(-max_shift, max_shift + 1): # -3개월(후행)부터 +3개월(선행)까지 하나씩 톱니바퀴를 돌려봄
        if h > 0:
            # [선행(Lead) 검증] shift(h): 약신호 데이터를 밑으로 h칸 밀어버림.
            # 즉, "과거의 인터넷 댓글 약신호"와 "미래의 실제 환자 수"를 같은 줄에 나란히 놓아 예측력을 테스트!
            shifted_signal = merged_df['weak_signal_score'].shift(h)
            actual_cases = merged_df[col_name]
        elif h < 0:
            # [후행(Lag) 검증] 반대로 실제 통계가 먼저 발생하고 인터넷 여론이 뒤늦게 따라오는 경우
            shifted_signal = merged_df['weak_signal_score']
            actual_cases = merged_df[col_name].shift(-h)
        else:
            # [동시(Coincident)] h=0, 즉 시차 없이 같은 달에 발생하는 경우
            shifted_signal = merged_df['weak_signal_score']
            actual_cases = merged_df[col_name]
            
        # ~np.isnan: shift로 인해 행이 엇갈리면서 발생한 빈칸(NaN)들을 물결(~) 기호를 써서 "빈칸이 아닌 것들만(True)" 솎아냄
        valid_idx = ~np.isnan(shifted_signal) & ~np.isnan(actual_cases)
        
        # 유효한 데이터가 충분할 때만 피어슨 상관계수 연산 수행
        if valid_idx.sum() > 2:
            # r: 1에 가까울수록 똑같이 움직임 / p_value: 0.05 미만이어야 "우연이 아닌 진짜 통계적 의미가 있음"을 증명
            r, p_value = pearsonr(shifted_signal[valid_idx], actual_cases[valid_idx])
            disease_correlations.append({'Time_Shift': h, 'Pearson_r': round(r, 4), 'p_value': round(p_value, 4)})
        
    corr_df = pd.DataFrame(disease_correlations)
    
    # .idxmax(): 상관계수(Pearson_r)가 가장 높게 나온 시차(h)가 몇 개월이었는지 그 1등 자리를 찾아냄
    best_h = corr_df.loc[corr_df['Pearson_r'].idxmax()]
    best_results.append({
        'Target': label_name,
        'Best_Shift_Months': int(best_h['Time_Shift']),
        'Max_Pearson_r': best_h['Pearson_r'],
        'P_value': best_h['p_value']
    })
    
    shift_type = "선행(Lead)" if best_h['Time_Shift'] > 0 else "후행" if best_h['Time_Shift'] < 0 else "동시"
    print(f"  👉 최적 시차: h={int(best_h['Time_Shift'])}개월 {shift_type} / r = {best_h['Pearson_r']:.4f} (p={best_h['p_value']:.4f})")

# 4. 검증 결과 종합 시각화 및 출력
summary_df = pd.DataFrame(best_results)

print("\n" + "="*55)
print(" 🎯 [최종 사후 예측(Hindcasting) 검증 결과 요약]")
print("="*55)
for idx, row in summary_df.iterrows():
    # 조건: 약신호가 1~3개월 선행(h>0)했고, 그 결과가 통계적으로 유의미(p<0.05)할 때 '성공' 판정!
    if row['Best_Shift_Months'] > 0 and row['P_value'] < 0.05:
        print(f" [성공] 모델의 약신호가 '{row['Target']}' 수치 급증을 {row['Best_Shift_Months']}개월 전에 선행(Lead)하여 예측함! (r={row['Max_Pearson_r']})")
    else:
        print(f" [보류] '{row['Target']}' 지표는 약신호와 통계적으로 유의미한 선행성을 보이지 않음.")
print("="*55 + "\n")
