#2 자연어 전처리 및 노이즈 필터링 (NLP Preprocessing)
import re #RegularExpression 정규표현식
import pandas as pd
from konlpy.tag import Okt #OpenKoreanText, SNS특화 형태소 분석기

print("[*] 1단계에서 수집한 네이버 뉴스 댓글 데이터를 불러옵니다...")

try:
    df_raw = pd.read_csv("naver_news_comments_raw.csv")
    print(f"  - 불러오기 성공! 총 {len(df_raw)}건의 데이터를 전처리합니다.")
except FileNotFoundError:
    print("[-] 'naver_news_comments_raw.csv' 파일이 없습니다. 1단계를 먼저 실행해 주세요.")
    
stopwords_list = [] #불용어사전
synonym_dict = {} # 도메인 지식에 기반하여 계속 추가 가능
okt = Okt()

def preprocess_korean_text(text): # 텍스트 정제 및 형태소 분석 함수 정의
    if not isinstance(text, str):
        return "" # 들어온 text가 str(문자열)이 아니면 빈칸으로 만듦
    text = re.sub(r'[^가-힣a-zA-Z0-9\s]',' ', text) #re.sub( ① 찾을 패턴 , ② 이걸로 바꿔라 , ③ 원본 텍스트 ) 특수문자, 이모티콘 등 공백으로 (substitute)
    text = re.sub(r'\s+', ' ', text).strip() # 다중 공백을 공백으로 바꾸고, strip으로 제거하기
    pos_tokens = okt.pos(text, norm=True, stem=True) # part of speech,pos tagging, norm 정규화, stem 어간추출(동사 형용사 추출에 중요)
    
    cleaned_tokens = []
    
    for word, pos in pos_tokens: # pos_tokens = [('영화', 'Noun'), ('진짜', 'Noun'), ...]
        if pos in ['Noun', 'Adjective', 'Verb']:  # 명사(Noun), 형용사(Adjective), 동사(Verb) 타겟팅하여 추출
            if len(word) <= 1 or word in stopwords_list: 
                continue #이 단어는 버리고 다음 단어로 넘어가!
            final_word = synonym_dict.get(word, word) #.get( ① 찾을 단어 , ② 사전에 없을 경우 뱉어낼 기본값 )
            cleaned_tokens.append(final_word)
    return ' '.join(cleaned_tokens) #리스트 안에 있는 여러 개의 글자들을 하나의 긴 문자열로 찰싹 붙여주는 역할, 각 단어 안에 ' ' 띄어쓰기 하고

print("\n 결측치 제거 및 시계열 정렬 중...") # 데이터프레임 전처리 및 시계열 정렬 실행
df_clean = df_raw.dropna(subset=['text', 'date']) #결측치 제거
df_clean = df_clean.drop_duplicates(subset=['text'], ignore_index=True) #중복 제거

df_clean['date'] = pd.to_datetime(df_clean['date'], errors='coerce')  #datetime으로, 
df_clean = df_clean.dropna(subset=['date']) # 날짜 변환 실패한 쓰레기값 제거
df_clean = df_clean.sort_values(by='date', ascending=True).reset_index(drop=True) #시계열 정렬

print(" 형태소 분석 및 사전 필터링 적용 중... (데이터 양에 따라 수 분이 소요될 수 있습니다)")
df_clean['final_text'] = df_clean['text'].apply(preprocess_korean_text) # NLP 함수 적용
df_clean = df_clean[df_clean['final_text'].str.strip() != ""].reset_index(drop=True) # 명사가 하나도 안 뽑혀서 빈칸("")이 된 데이터 최종 제거

output_filename = "naver_news_comments_cleaned.csv"
df_clean.to_csv(output_filename, index=False, encoding='utf-8-sig') # 정제 완료 데이터 저장

print(f'\n 자연어 전처리 및 시계열 정렬 완료')
print(f"  - 정제된 유효 데이터 총 {len(df_clean)}건이 '{output_filename}'에 저장되었습니다.")
print(df_clean[['Search_Keyword', 'date', 'text', 'final_text']].head(10)) # 1단계에서 추출했던 검색어, 공감수 등의 데이터도 잘 살아있는지 확인!
